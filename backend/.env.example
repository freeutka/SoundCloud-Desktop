PORT=3000

DATABASE_URL=postgres://soundcloud:soundcloud@localhost:5432/soundcloud_desktop
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USERNAME=soundcloud
DATABASE_PASSWORD=soundcloud
DATABASE_NAME=soundcloud_desktop
PG_POOL_MAX=20
PG_ACQUIRE_TIMEOUT_SECS=10

REDIS_URL=redis://localhost:6379

NATS_URL=nats://localhost:4222

QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

STORAGE_URL=https://storage.example.com
STREAMING_SERVICE_URL=http://localhost:8080
INTERNAL_TOKEN=

SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
SOUNDCLOUD_REDIRECT_URI=http://localhost:3000/auth/callback
SC_PROXY_URL=
SC_PROXY_FALLBACK=false

ADMIN_TOKEN=

SUBSCRIPTIONS_SNAPSHOT_DIR=/snapshots

SOUNDWAVE_COLLAB_WEIGHT=0.55
SOUNDWAVE_AUDIO_WEIGHT=0.20
SOUNDWAVE_CLAP_WEIGHT=0.10
SOUNDWAVE_LYRICS_WEIGHT=0.15
SOUNDWAVE_POPULARITY_BOOST=0
SOUNDWAVE_ARTIST_CAP=2
SOUNDWAVE_SCORE_THRESHOLD=0.05

COLLAB_AUTO_TRAIN=true
COLLAB_TRIGGER_EVENTS=100
COLLAB_TRIGGER_COOLDOWN_MS=600000
COLLAB_DIM=128
COLLAB_MIN_COUNT=3
COLLAB_MIN_SESSIONS=20

LTR_AUTO_TRAIN=true
LTR_RERANK_ENABLED=true

LYRICS_INDEXING_CONCURRENCY=3
NETEASE_API_BASE=https://ncm.nekohasegawa.com
MUSIXMATCH_API_BASE=https://apic-desktop.musixmatch.com/ws/1.1

TLS_ENABLED=false
DOMAINS=
ACME_EMAIL=
ACME_CACHE_DIR=/var/cache/acme
ACME_STAGING=false
TLS_HTTPS_PORT=443
TLS_HTTP_PORT=80
TLS_HTTP_REDIRECT=true

RUST_LOG=info,backend=debug,sqlx=warn
